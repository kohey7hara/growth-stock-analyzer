# --- テクニカル分析パラメータ ---
technical:
  sma_short: 20       # 短期移動平均 (日)
  sma_long: 50        # 長期移動平均 (日)
  sma_trend: 200      # トレンド移動平均 (日)
  rsi_period: 14      # RSI期間
  rsi_oversold: 30    # RSI 売られすぎ閾値
  rsi_overbought: 70  # RSI 買われすぎ閾値
  macd_fast: 12       # MACD 短期
  macd_slow: 26       # MACD 長期
  macd_signal: 9      # MACD シグナル
  bb_period: 20       # ボリンジャーバンド期間
  bb_std: 2           # ボリンジャーバンド標準偏差

# --- SNSセンチメント設定 ---
sentiment:
  google_trends_period: "3m"       # 過去3ヶ月
  reddit_subreddits:
    - "wallstreetbets"
    - "stocks"
    - "investing"
    - "options"
  reddit_lookback_days: 7          # 過去7日間のメンション数を取得
  twitter_lookback_hours: 24       # 過去24時間のツイート数

# --- スコアリング重み ---
scoring:
  weights:
    technical_score: 0.35     # テクニカル分析 (35%)
    fundamental_score: 0.30   # ファンダメンタルズ (30%)
    sentiment_score: 0.20     # SNSセンチメント (20%)
    momentum_score: 0.15      # モメンタム/出来高 (15%)

# --- 出力設定 ---
output:
  excel_path: "output/growth_stock_report.xlsx"
  csv_path: "data/latest_data.csv"
  history_path: "data/history/"
  log_path: "logs/analyzer.log"
