# ============================================================
# Growth Stock Analyzer - 設定ファイル (テンプレート)
# ============================================================
# このファイルを config.yaml にコピーして使用してください:
#   cp config.yaml.example config.yaml

# --- API Keys ---
# 各APIの無料プランでの制限:
#   Alpha Vantage: 25リクエスト/日 (無料), $49.99/月で無制限
#   Reddit: 100リクエスト/分 (OAuth, 無料)
#   X (Twitter): $100/月 (Basic), $5,000/月 (Pro)
#   Google Trends: 無料 (レート制限あり)

api_keys:
  alpha_vantage: "YOUR_ALPHA_VANTAGE_KEY"    # https://www.alphavantage.co/support/#api-key で無料取得
  reddit_client_id: "YOUR_REDDIT_CLIENT_ID"   # https://www.reddit.com/prefs/apps で作成
  reddit_client_secret: "YOUR_REDDIT_SECRET"
  reddit_user_agent: "GrowthStockAnalyzer/1.0"
  twitter_bearer_token: "YOUR_TWITTER_BEARER_TOKEN"  # https://developer.x.com/

# --- 分析対象銘柄 ---
# ticker: Yahoo Financeのティッカーシンボル
# name: 表示名
# sector: セクター分類
# market: us or jp

